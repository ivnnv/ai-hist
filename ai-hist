    row = conn.execute(
        "SELECT id, source, session_id, project, timestamp_ms "
        "FROM history WHERE id = ?",
        (args.id,),
    ).fetchone()
    if not row:
        conn.close()
        print(f"No entry with id {args.id}")
        sys.exit(1)
    id_, source, session_id, project, ts_ms = row

    # Same session
    if session_id:
        session_rows = conn.execute(
            "SELECT id, source, project, prompt, timestamp_ms "
            "FROM history WHERE session_id = ? ORDER BY timestamp_ms ASC",
            (session_id,),
        ).fetchall()
        if session_rows:
            print(f"  === Session {session_id} ({len(session_rows)} entries) ===\n")
            for r in session_rows:
                marker = " >>>" if r[0] == id_ else "    "
                print(f"{marker}{fmt_row(*r)}")
            print()

    # Nearby in time (±5 min), excluding same session
    window_ms = args.window * 60 * 1000
    nearby_sql = (
        "SELECT id, source, project, prompt, timestamp_ms "
        "FROM history WHERE timestamp_ms BETWEEN ? AND ? "
        "AND (session_id IS NULL OR session_id != ?) "
        "ORDER BY timestamp_ms ASC"
    )
    nearby_rows = conn.execute(
        nearby_sql, (ts_ms - window_ms, ts_ms + window_ms, session_id or "")
    ).fetchall()
    if nearby_rows:
        print(f"  === Nearby ({args.window}min window, other sessions) ===\n")
        for r in nearby_rows:
            print(f"    {fmt_row(*r)}")

    conn.close()


