#!/usr/bin/env python3
"""
ai-hist: Sync and search AI CLI conversation history in SQLite.

Supports Claude Code and Codex CLI out of the box.
Zero dependencies — Python 3.8+ standard library only.
"""

import argparse
import gzip
import hashlib
import json
import os
import sqlite3
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path

# --- Configuration -----------------------------------------------------------

DEFAULT_DB = os.path.join(os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local" / "share")), "ai-hist", "ai-history.db")
DB_PATH = Path(os.environ.get("AI_HIST_DB", DEFAULT_DB))
STATE_PATH = DB_PATH.parent / ".sync-state.json"

SOURCES = {
    "claude": Path.home() / ".claude" / "history.jsonl",
    "codex": Path.home() / ".codex" / "history.jsonl",
}

CODEX_SESSIONS_DIRS = [
    Path.home() / ".codex" / "sessions",
    Path.home() / ".codex" / "archived_sessions",
]

CURSOR_ROOT = Path.home() / ".cursor" / "projects"

# --- Schema ------------------------------------------------------------------

SCHEMA = """\
CREATE TABLE IF NOT EXISTS history (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    source TEXT NOT NULL,
    session_id TEXT,
    project TEXT,
    prompt TEXT NOT NULL,
    prompt_hash TEXT,
    timestamp_ms INTEGER NOT NULL,
    UNIQUE(source, timestamp_ms, prompt)
);
CREATE VIRTUAL TABLE IF NOT EXISTS history_fts USING fts5(
    prompt, project, content='history', content_rowid='id'
);
CREATE TRIGGER IF NOT EXISTS history_ai AFTER INSERT ON history BEGIN
    INSERT INTO history_fts(rowid, prompt, project)
    VALUES (new.id, new.prompt, new.project);
END;
CREATE TRIGGER IF NOT EXISTS history_au AFTER UPDATE ON history BEGIN
    INSERT INTO history_fts(history_fts, rowid, prompt, project)
    VALUES('delete', old.id, old.prompt, old.project);
    INSERT INTO history_fts(rowid, prompt, project)
    VALUES (new.id, new.prompt, new.project);
END;
CREATE TRIGGER IF NOT EXISTS history_ad AFTER DELETE ON history BEGIN
    INSERT INTO history_fts(history_fts, rowid, prompt, project)
    VALUES('delete', old.id, old.prompt, old.project);
END;
"""

# --- Helpers -----------------------------------------------------------------

def _prompt_hash(prompt):
    """First 16 hex chars of SHA-256 of the prompt — stored for future dedup queries."""
    return hashlib.sha256(prompt.encode()).hexdigest()[:16]


def _shell_quote(value):
    import re
    if re.match(r'^[A-Za-z0-9_./-]+$', value):
        return value
    return "'" + value.replace("'", "'\\''") + "'"


def _resume_cmd(source, session_id, project):
    """Build the CLI command to resume a session. Returns None for sources without resume."""
    if not session_id:
        return None
    if source == "claude":
        if project:
            return f"cd {_shell_quote(project)} && claude --resume {_shell_quote(session_id)}"
        return f"claude --resume {_shell_quote(session_id)}"
    if source == "codex":
        return f"codex resume {_shell_quote(session_id)}"
    if source == "cursor":
        cmd = f"cursor-agent --resume={_shell_quote(session_id)}"
        if project:
            return f"cd {_shell_quote(project)} && {cmd}"
        return cmd
    return None


def _build_fts_query(terms, raw=False):
    """Build an FTS5 query string from a list of terms.

    Auto-detects FTS5 operators (uppercase AND/OR/NOT, trailing *,
    pre-quoted phrases) and passes through raw. Leading - terms are converted
    to FTS5 NOT clauses. Otherwise quotes each term for literal matching,
    which is the safe default for most user input.
    Use raw=True or --fts to force raw FTS5 expression passthrough.
    """
    if raw:
        return " ".join(terms)
    fts_ops = {"AND", "OR", "NOT"}
    positives = []
    negatives = []
    for t in terms:
        if t in fts_ops or t.endswith("*") or (t.startswith('"') and t.endswith('"')):
            return " ".join(terms)
        if t.startswith("-") and len(t) > 1:
            negatives.append(t[1:])
        else:
            positives.append(t)
    if negatives and not positives:
        return '"__ai_hist_no_positive_terms__"'
    query = " ".join(_quote_fts_term(t) for t in positives)
    if negatives:
        query += " NOT " + " NOT ".join(_quote_fts_term(t) for t in negatives)
    return query


def _quote_fts_term(term):
    return '"' + term.replace('"', '""') + '"'


def _row_to_dict(id_, source, session_id, project, prompt, ts_ms):
    return {
        "id": id_,
        "source": source,
        "session_id": session_id,
        "project": project,
        "prompt": prompt,
        "timestamp_ms": ts_ms,
    }


# --- Parsers -----------------------------------------------------------------

def parse_claude(line: str):
    """Parse a Claude Code history.jsonl line."""
    obj = json.loads(line)
    display = obj.get("display", "").strip()
    if not display:
        return None
    return {
        "source": "claude",
        "session_id": obj.get("sessionId"),
        "project": obj.get("project"),
        "prompt": display,
        "prompt_hash": _prompt_hash(display),
        "timestamp_ms": obj.get("timestamp", 0),
    }


def parse_codex(line: str):
    """Parse a Codex CLI history.jsonl line."""
    obj = json.loads(line)
    text = obj.get("text", "").strip()
    if not text:
        return None
    return {
        "source": "codex",
        "session_id": obj.get("session_id"),
        "project": None,
        "prompt": text,
        "prompt_hash": _prompt_hash(text),
        "timestamp_ms": int(obj.get("ts", 0) * 1000),
    }


PARSERS = {
    "claude": parse_claude,
    "codex": parse_codex,
}


# --- Codex session enrichment ------------------------------------------------
# Codex `history.jsonl` entries don't carry the working directory. The rollout
# files under ~/.codex/sessions/**/rollout-*.jsonl do — their first line is a
# `session_meta` event with `payload.id` and `payload.cwd`. We build a
# session_id → cwd map at sync time and use it to populate `project`.

def _read_codex_session_meta(path: Path):
    """Read a codex rollout file's first line; return (session_id, cwd) or None."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            first = f.readline()
    except OSError:
        return None
    first = first.strip()
    if not first:
        return None
    try:
        obj = json.loads(first)
    except json.JSONDecodeError:
        return None
    if obj.get("type") != "session_meta":
        return None
    payload = obj.get("payload") or {}
    session_id = payload.get("id")
    cwd = payload.get("cwd")
    if not session_id or not cwd:
        return None
    return session_id, cwd


def build_codex_session_map(state: dict) -> dict:
    """Walk codex rollout dirs; cache and return {session_id: cwd}.

    Rollout files are write-once after the session_meta header — we key the
    rollout cache by path and skip any file whose mtime hasn't changed since
    we last scanned it.
    """
    seen = state.get("codex_rollouts", {})
    cwds = state.get("codex_session_cwds", {})
    scanned = 0
    for root in CODEX_SESSIONS_DIRS:
        if not root.exists():
            continue
        for rollout in root.rglob("rollout-*.jsonl"):
            key = str(rollout)
            try:
                mtime = int(rollout.stat().st_mtime)
            except OSError:
                continue
            if seen.get(key) == mtime:
                continue
            meta = _read_codex_session_meta(rollout)
            seen[key] = mtime
            scanned += 1
            if meta:
                sid, cwd = meta
                cwds[sid] = cwd
    state["codex_rollouts"] = seen
    state["codex_session_cwds"] = cwds
    if scanned:
        print(f"  [codex] scanned {scanned:,} new rollout files; {len(cwds):,} sessions mapped")
    return cwds


def _backfill_codex_projects(conn: sqlite3.Connection, cwds: dict) -> int:
    """Set project for codex rows with NULL project whose session_id is mapped."""
    if not cwds:
        return 0
    sids = conn.execute(
        "SELECT DISTINCT session_id FROM history "
        "WHERE source='codex' AND project IS NULL AND session_id IS NOT NULL"
    ).fetchall()
    updated = 0
    for (sid,) in sids:
        cwd = cwds.get(sid)
        if not cwd:
            continue
        cur = conn.execute(
            "UPDATE history SET project = ? "
            "WHERE source='codex' AND project IS NULL AND session_id = ?",
            (cwd, sid),
        )
        updated += cur.rowcount
    if updated:
        conn.commit()
    return updated


def sync_codex(conn: sqlite3.Connection, state: dict):
    """Import ~/.codex/history.jsonl, enriching `project` from rollout session_meta."""
    path = SOURCES["codex"]
    if not path.exists():
        print(f"  [codex] not found: {path} (skipped)")
        return

    cwds = build_codex_session_map(state)

    file_size = path.stat().st_size
    offset = state.get("codex", 0)
    inserted = 0
    errors = 0

    if offset < file_size:
        print(f"  [codex] syncing {file_size - offset:,} new bytes...")
        with open(path, "r", encoding="utf-8") as f:
            f.seek(offset)
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = parse_codex(line)
                except (json.JSONDecodeError, KeyError, TypeError):
                    errors += 1
                    continue
                if row is None:
                    continue
                sid = row.get("session_id")
                if sid and not row.get("project"):
                    row["project"] = cwds.get(sid)
                try:
                    cur = conn.execute(
                        "INSERT OR IGNORE INTO history "
                        "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                        "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                        row,
                    )
                    if cur.rowcount > 0:
                        inserted += 1
                except sqlite3.Error:
                    errors += 1
        conn.commit()
        state["codex"] = file_size

    backfilled = _backfill_codex_projects(conn, cwds)

    if offset >= file_size and not backfilled:
        print("  [codex] up to date")
        return
    parts = [f"+{inserted:,} rows"] if inserted or offset < file_size else []
    if backfilled:
        parts.append(f"backfilled {backfilled:,} project values")
    if errors:
        parts.append(f"{errors} errors")
    print(f"  [codex] " + ", ".join(parts))


def parse_cursor_line(line: str):
    """Extract a user prompt from a cursor agent-transcripts jsonl line.

    Cursor lines have shape `{role, message: {content: [{type, text}, ...]}}`
    and carry no per-line timestamp. User prompts are wrapped in
    `<user_query>...</user_query>`.
    """
    obj = json.loads(line)
    if obj.get("role") != "user":
        return None
    msg = obj.get("message") or {}
    content = msg.get("content")
    text = ""
    if isinstance(content, str):
        text = content
    elif isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                text = c.get("text", "")
                break
    text = text.strip()
    if not text:
        return None
    if text.startswith("<user_query>") and text.endswith("</user_query>"):
        text = text[len("<user_query>"):-len("</user_query>")].strip()
    return text or None


def _decode_cursor_project(name: str) -> str:
    """Decode an encoded cursor project dir name back into a filesystem path."""
    return "/" + name.replace("-", "/")


def sync_cursor(conn: sqlite3.Connection, state: dict):
    """Sync user prompts from ~/.cursor/projects/*/agent-transcripts/."""
    if not CURSOR_ROOT.exists():
        return

    cursor_state = state.get("cursor", {})
    inserted = 0
    errors = 0
    files_seen = 0

    for project_dir in sorted(CURSOR_ROOT.iterdir()):
        if not project_dir.is_dir():
            continue
        ts_root = project_dir / "agent-transcripts"
        if not ts_root.is_dir():
            continue
        project_path = _decode_cursor_project(project_dir.name)
        for session_dir in sorted(ts_root.iterdir()):
            if not session_dir.is_dir():
                continue
            session_id = session_dir.name
            jsonl = session_dir / f"{session_id}.jsonl"
            if not jsonl.exists():
                continue
            files_seen += 1
            try:
                stat = jsonl.stat()
            except OSError:
                errors += 1
                continue
            offset = cursor_state.get(str(jsonl), 0)
            if offset >= stat.st_size:
                continue
            ts_ms = int(stat.st_mtime * 1000)
            try:
                with open(jsonl, "r", encoding="utf-8") as f:
                    f.seek(offset)
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            text = parse_cursor_line(line)
                        except (json.JSONDecodeError, KeyError, TypeError):
                            errors += 1
                            continue
                        if not text:
                            continue
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (?, ?, ?, ?, ?, ?)",
                                ("cursor", session_id, project_path, text, _prompt_hash(text), ts_ms),
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
            except OSError:
                errors += 1
                continue
            cursor_state[str(jsonl)] = stat.st_size

    conn.commit()
    state["cursor"] = cursor_state
    if files_seen:
        suffix = f" ({errors} errors)" if errors else ""
        print(f"  [cursor] +{inserted:,} rows from {files_seen} files{suffix}")

# --- Relaycast API -----------------------------------------------------------

RELAYCAST_BASE = os.environ.get("RELAYCAST_BASE_URL", "https://api.relaycast.dev")
RELAYCAST_API_KEY = os.environ.get("RELAYCAST_API_KEY", "")
RELAYCAST_WORKSPACE_ID = os.environ.get("RELAYCAST_WORKSPACE_ID", "")


def relaycast_get(path: str, params: dict = None) -> dict:  # pragma: no cover
    """Make a GET request to the Relaycast API."""
    url = f"{RELAYCAST_BASE}/v1/{path}"
    if params:
        qs = "&".join(f"{k}={v}" for k, v in params.items() if v is not None)
        if qs:
            url += f"?{qs}"
    req = urllib.request.Request(url, headers={
        "Authorization": f"Bearer {RELAYCAST_API_KEY}",
        "Accept": "application/json",
    })
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode())


def sync_relaycast(conn: sqlite3.Connection, state: dict):
    """Sync messages from Relaycast API into the history table."""
    if not RELAYCAST_API_KEY or not RELAYCAST_WORKSPACE_ID:
        return

    relay_state = state.get("relay", {})
    inserted = 0
    errors = 0

    try:
        # Sync channel messages
        resp = relaycast_get("channels")
        channels = resp.get("data", []) if resp.get("ok") else []

        for ch in channels:
            ch_name = ch.get("name", "")
            last_id = relay_state.get(f"ch:{ch_name}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"channels/{ch_name}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"#{ch_name}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                # If we got fewer than limit, we're done
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"ch:{ch_name}"] = max_id

        # Sync DM conversations
        try:
            resp = relaycast_get("dm/conversations/all")
            conversations = resp.get("data", []) if resp.get("ok") else []
        except urllib.error.HTTPError:
            conversations = []

        for conv in conversations:
            conv_id = conv.get("id", "")
            if not conv_id:
                continue
            last_id = relay_state.get(f"dm:{conv_id}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"dm/conversations/{conv_id}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"dm:{conv_id}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"dm:{conv_id}"] = max_id

        conn.commit()
        state["relay"] = relay_state
        print(f"  [relay] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
        print(f"  [relay] API error: {e}")
    except Exception as e:
        print(f"  [relay] error: {e}")


def _relay_msg_to_row(msg: dict, channel: str):
    """Convert a Relaycast message to a history row."""
    text = msg.get("text", "")
    if not text:
        return None
    sender = msg.get("from_name") or msg.get("from_id") or ""
    created_at = msg.get("created_at", "")
    ts_ms = _iso_to_ms(created_at) if created_at else 0
    prompt = f"[{sender}] {text}" if sender else text
    return {
        "source": "relay",
        "session_id": msg.get("thread_id") or channel,
        "project": RELAYCAST_WORKSPACE_ID,
        "prompt": prompt,
        "prompt_hash": _prompt_hash(prompt),
        "timestamp_ms": ts_ms,
    }


def _iso_to_ms(iso_str: str) -> int:
    """Parse ISO 8601 datetime string to milliseconds since epoch."""
    iso_str = iso_str.rstrip("Z").split("+")[0]
    frac = 0
    if "." in iso_str:
        base, frac_str = iso_str.rsplit(".", 1)
        frac = int(frac_str.ljust(3, "0")[:3])
        iso_str = base
    try:
        t = time.strptime(iso_str, "%Y-%m-%dT%H:%M:%S")
    except ValueError:
        return 0
    return int(time.mktime(t)) * 1000 + frac


# --- Core --------------------------------------------------------------------

def init_db(conn: sqlite3.Connection):
    conn.executescript(SCHEMA)
    conn.execute("PRAGMA journal_mode=WAL")
    # Migration: add prompt_hash column to existing DBs that predate it.
    try:
        conn.execute("ALTER TABLE history ADD COLUMN prompt_hash TEXT")
        conn.commit()
    except sqlite3.OperationalError:
        pass  # column already exists
    conn.execute("CREATE INDEX IF NOT EXISTS idx_history_hash ON history(prompt_hash)")


def load_state() -> dict:
    if STATE_PATH.exists():
        return json.loads(STATE_PATH.read_text())
    return {}


def save_state(state: dict):
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def fmt_row(id_, source, project, prompt, ts_ms, verbose=False):
    """Format a single row for display."""
    dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000))
    proj = f" [{project}]" if project else ""
    if verbose:
        display = prompt
    else:
        display = prompt[:120] + "..." if len(prompt) > 120 else prompt
        display = display.replace("\n", " ")
    return f"  #{id_:<5} {dt}  ({source}){proj}  {display}"


# --- Commands ----------------------------------------------------------------

def cmd_sync(args=None):
    """Import new entries from history files into SQLite."""
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    state = load_state()

    for name, path in SOURCES.items():
        if name == "codex":
            # Codex is handled by sync_codex with rollout-derived cwd enrichment.
            continue
        if not path.exists():
            print(f"  [{name}] not found: {path} (skipped)")
            continue

        file_size = path.stat().st_size
        offset = state.get(name, 0)
        if offset >= file_size:
            print(f"  [{name}] up to date")
            continue

        print(f"  [{name}] syncing {file_size - offset:,} new bytes...")
        parser = PARSERS[name]
        inserted = 0
        errors = 0

        with open(path, "r", encoding="utf-8") as f:
            f.seek(offset)
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = parser(line)
                except (json.JSONDecodeError, KeyError, TypeError):
                    errors += 1
                    continue
                if row is None:
                    continue
                try:
                    cur = conn.execute(
                        "INSERT OR IGNORE INTO history "
                        "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                        "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                        row,
                    )
                    if cur.rowcount > 0:
                        inserted += 1
                except sqlite3.Error:
                    errors += 1

        conn.commit()
        state[name] = file_size
        print(f"  [{name}] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    # Sync Codex history with cwd enrichment from rollout files
    sync_codex(conn, state)

    # Sync Cursor agent transcripts (auto-discovered, no config needed)
    sync_cursor(conn, state)

    # Sync Relaycast (opt-in via env vars)
    sync_relaycast(conn, state)

    save_state(state)
    total = conn.execute("SELECT COUNT(*) FROM history").fetchone()[0]
    conn.close()
    print(f"  Total: {total:,} entries")


def cmd_search(args):
    """Full-text search across prompts."""
    conn = sqlite3.connect(str(DB_PATH))
    query = _build_fts_query(args.query, getattr(args, "fts", False))

    sql = (
        "SELECT h.id, h.source, h.session_id, h.project, h.prompt, h.timestamp_ms "
        "FROM history_fts f JOIN history h ON f.rowid = h.id "
        "WHERE history_fts MATCH ? "
    )
    params = [query]
    if args.source:
        sql += "AND h.source = ? "
        params.append(args.source)
    if args.project:
        sql += "AND h.project LIKE ? "
        params.append(f"%{args.project}%")
    sql += "ORDER BY h.timestamp_ms DESC LIMIT ?"
    params.append(args.limit)

    rows = conn.execute(sql, params).fetchall()
    conn.close()

    if not rows:
        if getattr(args, "json", False):
            print(json.dumps([]))
        else:
            print("No results.")
        sys.exit(1)

    if getattr(args, "json", False):
        print(json.dumps([_row_to_dict(*r) for r in rows]))
        return

    for r in rows:
        id_, source, session_id, project, prompt, ts_ms = r
        print(fmt_row(id_, source, project, prompt, ts_ms))


def cmd_recent(args):
    """Show N most recent entries."""
    conn = sqlite3.connect(str(DB_PATH))
    sql = "SELECT id, source, session_id, project, prompt, timestamp_ms FROM history "
    params = []
    wheres = []
    if args.source:
        wheres.append("source = ?")
        params.append(args.source)
    if args.project:
        wheres.append("project LIKE ?")
        params.append(f"%{args.project}%")
    if wheres:
        sql += "WHERE " + " AND ".join(wheres) + " "
    sql += "ORDER BY timestamp_ms DESC LIMIT ?"
    params.append(args.n)
    rows = conn.execute(sql, params).fetchall()
    conn.close()

    if getattr(args, "json", False):
        print(json.dumps([_row_to_dict(*r) for r in rows]))
        return

    for r in rows:
        id_, source, session_id, project, prompt, ts_ms = r
        print(fmt_row(id_, source, project, prompt, ts_ms))


def cmd_show(args):
    """Show the full prompt for a given entry ID."""
    conn = sqlite3.connect(str(DB_PATH))
    row = conn.execute(
        "SELECT id, source, session_id, project, prompt, timestamp_ms "
        "FROM history WHERE id = ?",
        (args.id,),
    ).fetchone()
    if not row:
        conn.close()
        if getattr(args, "json", False):
            print(json.dumps({"error": f"no entry with id {args.id}"}))
        else:
            print(f"No entry with id {args.id}")
        sys.exit(1)

    id_, source, session_id, project, prompt, ts_ms = row
    dt = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(ts_ms / 1000))
    resume = _resume_cmd(source, session_id, project)

    if getattr(args, "json", False):
        session_count = None
        if session_id:
            session_count = conn.execute(
                "SELECT COUNT(*) FROM history WHERE session_id = ?", (session_id,)
            ).fetchone()[0]
        conn.close()
        out = _row_to_dict(id_, source, session_id, project, prompt, ts_ms)
        out["resume_cmd"] = resume
        out["session_count"] = session_count
        print(json.dumps(out))
        return

    print(f"  ID:        {id_}")
    print(f"  Source:    {source}")
    print(f"  Session:   {session_id or '(none)'}")
    print(f"  Project:   {project or '(none)'}")
    print(f"  Time:      {dt}")
    print(f"  Prompt:")
    print()
    print(prompt)

    print()
    if session_id:
        session_count = conn.execute(
            "SELECT COUNT(*) FROM history WHERE session_id = ?", (session_id,)
        ).fetchone()[0]
        print(f"  Session has {session_count} entries: ai-hist session {session_id}")
        if resume:
            print(f"  Resume:  {resume}")
    print(f"  Context: ai-hist context {id_}")
    conn.close()


def cmd_context(args):
    """Show entries around a given ID: same session + nearby in time."""
    conn = sqlite3.connect(str(DB_PATH))
    row = conn.execute(
        "SELECT id, source, session_id, project, timestamp_ms "
        "FROM history WHERE id = ?",
        (args.id,),
    ).fetchone()
    if not row:
        conn.close()
        print(f"No entry with id {args.id}")
        sys.exit(1)
    id_, source, session_id, project, ts_ms = row

    # Same session
    if session_id:
        session_rows = conn.execute(
            "SELECT id, source, project, prompt, timestamp_ms "
            "FROM history WHERE session_id = ? ORDER BY timestamp_ms ASC",
            (session_id,),
        ).fetchall()
        if session_rows:
            print(f"  === Session {session_id} ({len(session_rows)} entries) ===\n")
            for r in session_rows:
                marker = " >>>" if r[0] == id_ else "    "
                print(f"{marker}{fmt_row(*r)}")
            print()

    # Nearby in time (±5 min), excluding same session
    window_ms = args.window * 60 * 1000
    nearby_sql = (
        "SELECT id, source, project, prompt, timestamp_ms "
        "FROM history WHERE timestamp_ms BETWEEN ? AND ? "
        "AND (session_id IS NULL OR session_id != ?) "
        "ORDER BY timestamp_ms ASC"
    )
    nearby_rows = conn.execute(
        nearby_sql, (ts_ms - window_ms, ts_ms + window_ms, session_id or "")
    ).fetchall()
    if nearby_rows:
        print(f"  === Nearby ({args.window}min window, other sessions) ===\n")
        for r in nearby_rows:
            print(f"    {fmt_row(*r)}")

    conn.close()


def cmd_session(args):
    """Show all prompts in a given session."""
    conn = sqlite3.connect(str(DB_PATH))
    rows = conn.execute(
        "SELECT id, source, session_id, project, prompt, timestamp_ms "
        "FROM history WHERE session_id = ? ORDER BY timestamp_ms ASC",
        (args.session_id,),
    ).fetchall()
    conn.close()
    if not rows:
        if getattr(args, "json", False):
            print(json.dumps([]))
        else:
            print(f"No entries for session {args.session_id}")
        sys.exit(1)

    if getattr(args, "json", False):
        print(json.dumps([_row_to_dict(*r) for r in rows]))
        return

    print(f"  Session {args.session_id} ({len(rows)} entries):\n")
    for r in rows:
        id_, source, session_id, project, prompt, ts_ms = r
        print(fmt_row(id_, source, project, prompt, ts_ms, verbose=args.full))


def cmd_stats(args=None):
    """Show summary statistics."""
    conn = sqlite3.connect(str(DB_PATH))

    total = conn.execute("SELECT COUNT(*) FROM history").fetchone()[0]
    by_source = {
        source: count
        for source, count in conn.execute(
            "SELECT source, COUNT(*) FROM history GROUP BY source ORDER BY source"
        )
    }
    top_projects = [
        {"project": p, "count": c}
        for p, c in conn.execute(
            "SELECT project, COUNT(*) as c FROM history "
            "WHERE project IS NOT NULL GROUP BY project ORDER BY c DESC LIMIT 10"
        )
    ]
    r = conn.execute("SELECT MIN(timestamp_ms), MAX(timestamp_ms) FROM history").fetchone()
    conn.close()

    if getattr(args, "json", False):
        print(json.dumps({
            "total": total,
            "by_source": by_source,
            "top_projects": top_projects,
            "first_timestamp_ms": r[0],
            "last_timestamp_ms": r[1],
        }))
        return

    print(f"\nTotal entries: {total:,}")
    print("\nBy source:")
    for source, count in by_source.items():
        print(f"  {source}: {count:,}")
    if r[0]:
        print(f"\nDate range:")
        print(f"  {time.strftime('%Y-%m-%d', time.localtime(r[0] / 1000))} to "
              f"{time.strftime('%Y-%m-%d', time.localtime(r[1] / 1000))}")
    print("\nTop 10 projects:")
    for item in top_projects:
        print(f"  {item['count']:>6,}  {item['project']}")


def cmd_pack(args):
    """Generate a token-budget-aware evidence bundle for LLM handoff.

    Searches the same way as `search` and formats results as a numbered list
    with resume commands — ready to paste into an LLM context window.
    Use --tokens to truncate each prompt to approximately N tokens (4 chars/token).
    """
    conn = sqlite3.connect(str(DB_PATH))
    query = _build_fts_query(args.query, getattr(args, "fts", False))

    sql = (
        "SELECT h.id, h.source, h.session_id, h.project, h.prompt, h.timestamp_ms "
        "FROM history_fts f JOIN history h ON f.rowid = h.id "
        "WHERE history_fts MATCH ? "
    )
    params = [query]
    if args.source:
        sql += "AND h.source = ? "
        params.append(args.source)
    if args.project:
        sql += "AND h.project LIKE ? "
        params.append(f"%{args.project}%")
    sql += "ORDER BY h.timestamp_ms DESC LIMIT ?"
    params.append(args.limit)

    rows = conn.execute(sql, params).fetchall()
    conn.close()

    if not rows:
        if getattr(args, "json", False):
            print(json.dumps({"query": " ".join(args.query), "entries": []}))
        else:
            print("No results.")
        sys.exit(1)

    chars_budget = args.tokens * 4 if args.tokens else None
    query_str = " ".join(args.query)
    now_ms = int(time.time() * 1000)

    if getattr(args, "json", False):
        entries = []
        for r in rows:
            id_, source, session_id, project, prompt, ts_ms = r
            text = prompt[:chars_budget] if chars_budget and len(prompt) > chars_budget else prompt
            entries.append({
                "id": id_,
                "source": source,
                "session_id": session_id,
                "project": project,
                "prompt": text,
                "timestamp_ms": ts_ms,
                "resume_cmd": _resume_cmd(source, session_id, project),
            })
        print(json.dumps({
            "query": query_str,
            "generated_ms": now_ms,
            "token_budget": args.tokens,
            "entries": entries,
        }))
        return

    dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(now_ms / 1000))
    print(f'=== ai-hist pack: "{query_str}" | {dt} | {len(rows)} entries ===\n')
    for i, r in enumerate(rows, 1):
        id_, source, session_id, project, prompt, ts_ms = r
        entry_dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000))
        proj = f"  {project}" if project else ""
        if chars_budget and len(prompt) > chars_budget:
            text = prompt[:chars_budget].replace("\n", " ") + "..."
        else:
            text = prompt.replace("\n", " ")
        print(f"[{i}/{len(rows)}] #{id_}  {entry_dt}  {source}{proj}")
        print(f"      {text}")
        if session_id:
            cmd = _resume_cmd(source, session_id, project)
            sid_short = session_id[:16] + "..." if len(session_id) > 16 else session_id
            if cmd:
                print(f"      Resume: {cmd}")
            else:
                print(f"      Session: {sid_short}")
        print()


def cmd_resume(args):
    """Find the best session matching a query and print its resume command.

    Exits 0 and prints the command on success; exits 1 if no matching session
    is found. Ideal for shell aliases:
        alias rai='$(ai-hist resume)'
    """
    conn = sqlite3.connect(str(DB_PATH))
    query = _build_fts_query(args.query, getattr(args, "fts", False))

    sql = (
        "SELECT h.id, h.source, h.session_id, h.project, h.prompt, h.timestamp_ms "
        "FROM history_fts f JOIN history h ON f.rowid = h.id "
        "WHERE history_fts MATCH ? AND h.session_id IS NOT NULL AND h.session_id != '' "
        "ORDER BY h.timestamp_ms DESC LIMIT 1"
    )
    row = conn.execute(sql, [query]).fetchone()
    conn.close()

    if not row:
        if getattr(args, "json", False):
            print(json.dumps({"error": "no session found", "query": " ".join(args.query)}))
        else:
            print("No session found.", file=sys.stderr)
        sys.exit(1)

    id_, source, session_id, project, prompt, ts_ms = row
    cmd = _resume_cmd(source, session_id, project)

    if getattr(args, "json", False):
        out = _row_to_dict(id_, source, session_id, project, prompt, ts_ms)
        out["resume_cmd"] = cmd
        print(json.dumps(out))
        return

    if cmd:
        print(cmd)
    else:
        print(f"No resume command available for source '{source}'", file=sys.stderr)
        sys.exit(1)


def cmd_watch(args):
    """Continuous sync loop (for launchd/cron)."""
    interval = args.interval
    print(f"Watching every {interval}s (Ctrl-C to stop)...")
    while True:
        try:
            cmd_sync()
        except Exception as e:
            print(f"Error: {e}", file=sys.stderr)
        time.sleep(interval)


# --- Export / Import ---------------------------------------------------------

_EXPORT_FIELDS = ["source", "session_id", "project", "prompt", "prompt_hash", "timestamp_ms"]


def _parse_date_to_ms(date_str):
    try:
        t = time.strptime(date_str, "%Y-%m-%d")
        return int(time.mktime(t)) * 1000
    except ValueError:
        print(f"Invalid date '{date_str}'. Use YYYY-MM-DD.", file=sys.stderr)
        sys.exit(1)


def _open_file(path, mode="rt"):
    """Open a file, transparently handling .gz compression."""
    if path.endswith(".gz"):
        return gzip.open(path, mode, encoding="utf-8")
    return open(path, mode, encoding="utf-8")


def _query_export_rows(conn, args):
    sql = (
        "SELECT source, session_id, project, prompt, prompt_hash, timestamp_ms "
        "FROM history WHERE 1=1"
    )
    params = []
    if getattr(args, "source", None):
        sql += " AND source = ?"
        params.append(args.source)
    if getattr(args, "project", None):
        sql += " AND project LIKE ?"
        params.append(f"%{args.project}%")
    if getattr(args, "since", None):
        sql += " AND timestamp_ms >= ?"
        params.append(_parse_date_to_ms(args.since))
    sql += " ORDER BY timestamp_ms ASC"
    return conn.execute(sql, params).fetchall()


def cmd_export(args):
    """Export history to a portable JSONL or SQLite file.

    JSONL is the default — one JSON object per line, gzip-friendly, easy to
    inspect. SQLite exports a self-contained DB file that can be directly used
    as $AI_HIST_DB on another machine.

    Examples:
        ai-hist export                          # JSONL to stdout
        ai-hist export history.jsonl            # JSONL to file
        ai-hist export history.jsonl.gz         # gzip-compressed JSONL
        ai-hist export backup.db --format sqlite
        ai-hist export --source claude --since 2025-01-01 recent.jsonl
    """
    if not DB_PATH.exists():
        print(f"No database found at {DB_PATH}. Run `ai-hist sync` first.", file=sys.stderr)
        sys.exit(1)

    fmt = getattr(args, "format", "jsonl") or "jsonl"
    output = getattr(args, "output", None)

    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    rows = _query_export_rows(conn, args)
    conn.close()

    if not rows:
        print("No entries matched the export filters.", file=sys.stderr)
        sys.exit(1)

    if fmt == "sqlite":
        dest = output or "ai-hist-export.db"
        if Path(dest).resolve() == DB_PATH.resolve():
            print("Refusing to export SQLite over the active AI_HIST_DB.", file=sys.stderr)
            sys.exit(1)
        try:
            Path(dest).unlink()
        except FileNotFoundError:
            pass
        dst = sqlite3.connect(dest)
        init_db(dst)
        inserted = 0
        for row in rows:
            cur = dst.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                row,
            )
            if cur.rowcount > 0:
                inserted += 1
        dst.commit()
        dst.close()
        print(f"Exported {inserted:,} entries to {dest}")
        return

    # JSONL (default) — stdout or file
    def write_jsonl(f):
        for row in rows:
            f.write(json.dumps(dict(zip(_EXPORT_FIELDS, row))) + "\n")

    if output:
        with _open_file(output, "wt") as f:
            write_jsonl(f)
        print(f"Exported {len(rows):,} entries to {output}", file=sys.stderr)
    else:
        write_jsonl(sys.stdout)


def _load_rows_from_sqlite(path):
    """Load rows from an exported SQLite DB, tolerating missing prompt_hash."""
    try:
        src = sqlite3.connect(path)
        cols = {r[1] for r in src.execute("PRAGMA table_info(history)").fetchall()}
        if "prompt_hash" in cols:
            sql = "SELECT source, session_id, project, prompt, prompt_hash, timestamp_ms FROM history"
            fields = _EXPORT_FIELDS
        else:
            sql = "SELECT source, session_id, project, prompt, timestamp_ms FROM history"
            fields = ["source", "session_id", "project", "prompt", "timestamp_ms"]
        rows = [dict(zip(fields, r)) for r in src.execute(sql).fetchall()]
        src.close()
        return rows
    except sqlite3.Error as e:
        print(f"Error reading SQLite file: {e}", file=sys.stderr)
        sys.exit(1)


def _load_rows_from_jsonl(path):
    """Load rows from a JSONL (optionally gzip-compressed) export file."""
    rows = []
    try:
        with _open_file(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rows.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    except (OSError, EOFError) as e:
        print(f"Error reading {path}: {e}", file=sys.stderr)
        sys.exit(1)
    return rows


def cmd_import(args):
    """Import history from a JSONL or SQLite export file.

    Entries that already exist (same source + timestamp + prompt) are silently
    skipped, so it is safe to import the same file multiple times or merge
    overlapping exports from different machines.

    Examples:
        ai-hist import colleague.jsonl
        ai-hist import colleague.jsonl.gz
        ai-hist import colleague.db
        ai-hist import colleague.jsonl --dry-run
    """
    path = args.file
    dry_run = getattr(args, "dry_run", False)

    if path.endswith(".db") or path.endswith(".sqlite"):
        rows = _load_rows_from_sqlite(path)
    else:
        rows = _load_rows_from_jsonl(path)

    if not rows:
        print("No entries found in file.")
        return

    total = len(rows)

    if dry_run:
        print(f"[dry-run] {total:,} entries in {path} — none written.")
        print()
        for row in rows[:5]:
            source = row.get("source", "?")
            project = row.get("project") or ""
            prompt = row.get("prompt", "")[:80].replace("\n", " ")
            ts_ms = row.get("timestamp_ms", 0)
            dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000)) if ts_ms else "?"
            proj = f" [{project}]" if project else ""
            print(f"  {dt}  ({source}){proj}  {prompt}")
        if total > 5:
            print(f"  ... and {total - 5:,} more")
        return

    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)

    inserted = 0
    errors = 0
    for row in rows:
        prompt = row.get("prompt", "")
        if not prompt:
            continue
        try:
            cur = conn.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                (
                    row.get("source", ""),
                    row.get("session_id"),
                    row.get("project"),
                    prompt,
                    row.get("prompt_hash") or _prompt_hash(prompt),
                    row.get("timestamp_ms", 0),
                ),
            )
            if cur.rowcount > 0:
                inserted += 1
        except sqlite3.Error:
            errors += 1

    conn.commit()
    conn.close()

    skipped = total - inserted - errors
    parts = [f"+{inserted:,} new entries"]
    if skipped:
        parts.append(f"{skipped:,} already existed")
    if errors:
        parts.append(f"{errors} errors")
    print(f"Imported from {path}: {', '.join(parts)}")


