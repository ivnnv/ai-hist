    if not matches:
        conn.close()
        print(f"No session found for {args.session_id}", file=sys.stderr)
        sys.exit(1)

    now_ms = int(time.time() * 1000)
    changed = 0
    for source, session_id, project, count, last_ms in matches:
        cur = conn.execute(
            "INSERT OR IGNORE INTO session_tags (source, session_id, tag_id, created_ms) "
            "VALUES (?, ?, ?, ?)",
