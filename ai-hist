def main():
    p = argparse.ArgumentParser(prog="ai-hist", description="Sync & search AI CLI history in SQLite.")
    sub = p.add_subparsers(dest="command")

    sub.add_parser("sync", help="Import new entries from history files")

    s = sub.add_parser("search", help="Full-text search prompts")
    s.add_argument("query", nargs="+", help="Search terms (FTS5: AND/OR/NOT auto-detected; use --fts for raw)")
    s.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    s.add_argument("--project", help="Filter by project path (substring match)")
    s.add_argument("--limit", type=int, default=20, help="Max results (default: 20)")
    s.add_argument("--fts", action="store_true", help="Pass query through as raw FTS5 expression")
    s.add_argument("--json", action="store_true", help="Output as JSON array")

    r = sub.add_parser("recent", help="Show most recent entries")
    r.add_argument("n", nargs="?", type=int, default=20, help="Number of entries (default: 20)")
    r.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    r.add_argument("--project", help="Filter by project path (substring match)")
    r.add_argument("--json", action="store_true", help="Output as JSON array")

    sh = sub.add_parser("show", help="Show full details for an entry by ID")
    sh.add_argument("id", type=int, help="Entry ID (shown as #NNN in search/recent)")
    sh.add_argument("--json", action="store_true", help="Output as JSON object")

    se = sub.add_parser("session", help="Show all prompts in a session")
    se.add_argument("session_id", help="Session ID")
    se.add_argument("--full", action="store_true", help="Show full prompt text (no truncation)")
    se.add_argument("--json", action="store_true", help="Output as JSON array")

    cx = sub.add_parser("context", help="Show entries around an ID (same session + nearby)")
    cx.add_argument("id", type=int, help="Entry ID to get context for")
    cx.add_argument("--window", type=int, default=5, help="Time window in minutes (default: 5)")

    st = sub.add_parser("stats", help="Show summary statistics")
    st.add_argument("--json", action="store_true", help="Output as JSON object")

    pk = sub.add_parser("pack", help="Evidence bundle for LLM handoff (search + resume commands)")
    pk.add_argument("query", nargs="+", help="Search terms")
    pk.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    pk.add_argument("--project", help="Filter by project path (substring match)")
    pk.add_argument("--limit", type=int, default=10, help="Max entries (default: 10)")
    pk.add_argument("--tokens", type=int, default=0, help="Truncate each prompt to ~N tokens (4 chars/token)")
    pk.add_argument("--fts", action="store_true", help="Pass query through as raw FTS5 expression")
    pk.add_argument("--json", action="store_true", help="Output as JSON")

    rv = sub.add_parser("resume", help="Find best matching session and print its resume command")
    rv.add_argument("query", nargs="+", help="Search terms to find the session")
    rv.add_argument("--fts", action="store_true", help="Pass query through as raw FTS5 expression")
    rv.add_argument("--json", action="store_true", help="Output as JSON object")

    w = sub.add_parser("watch", help="Continuous sync loop")
    w.add_argument("--interval", type=int, default=60, help="Seconds between syncs (default: 60)")

    exp = sub.add_parser("export", help="Export history to a portable JSONL or SQLite file")
    exp.add_argument("output", nargs="?", help="Output file (default: stdout). Use .gz for compression.")
    exp.add_argument("--format", choices=["jsonl", "sqlite"], default="jsonl", help="Output format (default: jsonl)")
    exp.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    exp.add_argument("--project", help="Filter by project path (substring)")
    exp.add_argument("--since", metavar="YYYY-MM-DD", help="Only entries on or after this date")

    imp = sub.add_parser("import", help="Import history from an exported JSONL or SQLite file")
    imp.add_argument("file", help="File to import (.jsonl, .jsonl.gz, or .db)")
    imp.add_argument("--dry-run", action="store_true", help="Preview what would be imported without writing")

    args = p.parse_args()
    cmds = {
        "sync": cmd_sync, "search": cmd_search, "recent": cmd_recent,
        "show": cmd_show, "session": cmd_session, "context": cmd_context,
        "stats": cmd_stats, "pack": cmd_pack, "resume": cmd_resume,
        "watch": cmd_watch,
        "export": cmd_export, "import": cmd_import,
    }

    if args.command in cmds:
        cmds[args.command](args)
    else:
        p.print_help()


if __name__ == "__main__":  # pragma: no cover
    main()
