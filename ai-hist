# --- Helpers -----------------------------------------------------------------

def _prompt_hash(prompt):
    """First 16 hex chars of SHA-256 of the prompt — stored for future dedup queries."""
    return hashlib.sha256(prompt.encode()).hexdigest()[:16]


def _shell_quote(value):
    import re
    if re.match(r'^[A-Za-z0-9_./-]+$', value):
        return value
    return "'" + value.replace("'", "'\\''") + "'"


def _resume_cmd(source, session_id, project):
    """Build the CLI command to resume a session. Returns None for sources without resume."""
    if not session_id:
        return None
    if source == "claude":
        if project:
            return f"cd {_shell_quote(project)} && claude --resume {_shell_quote(session_id)}"
        return f"claude --resume {_shell_quote(session_id)}"
    if source == "codex":
        return f"codex resume {_shell_quote(session_id)}"
    if source == "cursor":
        cmd = f"cursor-agent --resume={_shell_quote(session_id)}"
        if project:
            return f"cd {_shell_quote(project)} && {cmd}"
        return cmd
    return None


def _build_fts_query(terms, raw=False):
    """Build an FTS5 query string from a list of terms.

    Auto-detects FTS5 operators (uppercase AND/OR/NOT, trailing *,
    pre-quoted phrases) and passes through raw. Leading - terms are converted
    to FTS5 NOT clauses. Otherwise quotes each term for literal matching,
    which is the safe default for most user input.
    Use raw=True or --fts to force raw FTS5 expression passthrough.
    """
    if raw:
        return " ".join(terms)
    fts_ops = {"AND", "OR", "NOT"}
    positives = []
    negatives = []
    for t in terms:
        if t in fts_ops or t.endswith("*") or (t.startswith('"') and t.endswith('"')):
            return " ".join(terms)
        if t.startswith("-") and len(t) > 1:
            negatives.append(t[1:])
        else:
            positives.append(t)
    if negatives and not positives:
        return '"__ai_hist_no_positive_terms__"'
    query = " ".join(_quote_fts_term(t) for t in positives)
    if negatives:
        query += " NOT " + " NOT ".join(_quote_fts_term(t) for t in negatives)
    return query


def _quote_fts_term(term):
    return '"' + term.replace('"', '""') + '"'


def _row_to_dict(id_, source, session_id, project, prompt, ts_ms):
    return {
        "id": id_,
        "source": source,
        "session_id": session_id,
        "project": project,
        "prompt": prompt,
        "timestamp_ms": ts_ms,
    }

def _normalize_tag_name(name: str) -> str:
    return " ".join(name.strip().lower().split())


def _tag_filter_clause(alias: str = "h") -> str:
    return (
        "EXISTS ("
        "SELECT 1 FROM session_tags st "
        "JOIN tags t ON t.id = st.tag_id "
        f"WHERE st.source = {alias}.source "
        f"AND st.session_id = {alias}.session_id "
        "AND t.name = ?"
        ")"
    )


def _session_tags(conn: sqlite3.Connection, source: str, session_id: str) -> list:
    return [
        {"name": name, "display_name": display_name, "color": color}
        for name, display_name, color in conn.execute(
            "SELECT t.name, t.display_name, t.color "
            "FROM tags t JOIN session_tags st ON st.tag_id = t.id "
            "WHERE st.source = ? AND st.session_id = ? "
            "ORDER BY t.name",
            (source, session_id),
        )
    ]


def _ensure_tag(conn: sqlite3.Connection, tag_name: str, color=None) -> int:
    normalized = _normalize_tag_name(tag_name)
    if not normalized:
        raise ValueError("tag name cannot be empty")
    now_ms = int(time.time() * 1000)
    conn.execute(
        "INSERT INTO tags (name, display_name, color, created_ms, updated_ms) "
        "VALUES (?, ?, ?, ?, ?) "
        "ON CONFLICT(name) DO UPDATE SET "
        "display_name = excluded.display_name, "
        "color = COALESCE(excluded.color, tags.color), "
        "updated_ms = excluded.updated_ms",
        (normalized, tag_name.strip(), color, now_ms, now_ms),
    )
    return conn.execute("SELECT id FROM tags WHERE name = ?", (normalized,)).fetchone()[0]


def _matching_sessions(conn: sqlite3.Connection, session_id: str, source=None) -> list:
    sql = (
        "SELECT source, session_id, MIN(project), COUNT(*), MAX(timestamp_ms) "
        "FROM history WHERE session_id = ?"
    )
    params = [session_id]
    if source:
        sql += " AND source = ?"
        params.append(source)
    sql += " GROUP BY source, session_id ORDER BY source"
    return conn.execute(sql, params).fetchall()


# --- Session helpers ---------------------------------------------------------

def _upsert_session(conn, session_id, source, cwd, git_branch, ts_ms,
                    last_assistant_text=None, raw_path=None):
    """Insert or update a row in the sessions table."""
    conn.execute(
        """
        INSERT INTO sessions
          (session_id, source, cwd, git_branch, first_activity_ms, last_activity_ms,
           last_assistant_text, raw_path, parser_version)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, 1)
        ON CONFLICT(session_id, source) DO UPDATE SET
          cwd                = COALESCE(excluded.cwd, sessions.cwd),
          git_branch         = COALESCE(excluded.git_branch, sessions.git_branch),
          first_activity_ms  = MIN(COALESCE(sessions.first_activity_ms, excluded.first_activity_ms),
                                   excluded.first_activity_ms),
          last_activity_ms   = MAX(COALESCE(sessions.last_activity_ms, excluded.last_activity_ms),
                                   excluded.last_activity_ms),
          last_assistant_text= COALESCE(excluded.last_assistant_text, sessions.last_assistant_text),
          raw_path           = COALESCE(excluded.raw_path, sessions.raw_path),
          parser_version     = excluded.parser_version
        """,
        (session_id, source, cwd, git_branch, ts_ms, ts_ms,
         last_assistant_text, raw_path),
    )


def _scan_claude_session_file(path: Path) -> dict | None:
    """
    Extract session metadata from a Claude per-session JSONL file.

    Reads the first 20 lines for sessionId/gitBranch/cwd/first-timestamp,
    then tails the last 64 KB for the most recent assistant turn.
    Returns a dict or None if the file can't be identified as a session.
    """
    MAX_TAIL = 65536
    session_id = git_branch = cwd = None
    first_ts = last_ts = None
    last_assistant_text = None

    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            for i, line in enumerate(f):
                if i >= 20:
                    break
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if not isinstance(obj, dict):
                    continue
                if session_id is None:
                    session_id = obj.get("sessionId")
                if git_branch is None:
                    git_branch = obj.get("gitBranch")
                if cwd is None:
                    cwd = obj.get("cwd")
                if first_ts is None:
                    raw_ts = obj.get("timestamp")
                    if isinstance(raw_ts, str):
                        first_ts = _iso_to_ms(raw_ts)
                    elif isinstance(raw_ts, (int, float)):
                        first_ts = int(raw_ts)
    except OSError:
        return None

    if not session_id:
        return None

    # Tail the file for last timestamp, last assistant text, and latest branch.
    # Going bottom-to-top means the first gitBranch we find is the most recent one,
    # which handles sessions that switched branches mid-way.
    tail_branch = None
    try:
        file_size = path.stat().st_size
        tail_offset = max(0, file_size - MAX_TAIL)
        with open(path, "rb") as fb:
            fb.seek(tail_offset)
            tail_bytes = fb.read()
        tail_text = tail_bytes.decode("utf-8", errors="replace")
        for line in reversed(tail_text.splitlines()):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(obj, dict):
                continue
            if last_ts is None:
                raw_ts = obj.get("timestamp")
                if isinstance(raw_ts, str):
                    last_ts = _iso_to_ms(raw_ts)
                elif isinstance(raw_ts, (int, float)):
                    last_ts = int(raw_ts)
            if tail_branch is None and obj.get("gitBranch"):
                tail_branch = obj["gitBranch"]
            if last_assistant_text is None and obj.get("type") == "assistant":
                msg = obj.get("message") or {}
                content = msg.get("content")
                if isinstance(content, str):
                    last_assistant_text = content[:4096]
                elif isinstance(content, list):
                    parts = []
                    for c in content:
                        if isinstance(c, dict) and c.get("type") == "text":
                            parts.append(str(c.get("text", "")))
                    if parts:
                        last_assistant_text = "\n".join(parts)[:4096]
            if last_ts is not None and tail_branch is not None and last_assistant_text is not None:
                break
    except OSError:
        pass
    # Prefer the latest-seen branch (from tail) over the initial branch (from head).
    if tail_branch:
        git_branch = tail_branch

    return {
        "session_id": session_id,
        "git_branch": git_branch,
        "cwd": cwd,
        "first_ts": first_ts or 0,
        "last_ts": last_ts or first_ts or 0,
        "last_assistant_text": last_assistant_text,
        "raw_path": str(path),
    }


def sync_claude_sessions(conn: sqlite3.Connection, state: dict):
    """
    Walk ~/.claude/projects/**/<session-id>.jsonl and populate the sessions table.
    Uses per-file mtime to skip unchanged files incrementally.
    """
    if not CLAUDE_PROJECTS_ROOT.exists():
        return

    session_state = state.get("claude_sessions", {})
    upserted = 0
    scanned = 0
    errors = 0

    for project_dir in CLAUDE_PROJECTS_ROOT.iterdir():
        if not project_dir.is_dir():
            continue
        for jsonl_path in project_dir.glob("*.jsonl"):
            key = str(jsonl_path)
            try:
                st = jsonl_path.stat()
                mtime = f"{st.st_mtime_ns}:{st.st_size}"
            except OSError:
                errors += 1
                continue
            if session_state.get(key) == mtime:
                continue
            scanned += 1
            meta = _scan_claude_session_file(jsonl_path)
            session_state[key] = mtime
            if not meta:
                continue
            try:
                _upsert_session(
                    conn,
                    meta["session_id"],
                    "claude",
                    meta["cwd"],
                    meta["git_branch"],
                    meta["first_ts"],
                    last_assistant_text=meta["last_assistant_text"],
                    raw_path=meta["raw_path"],
                )
                # Update last_activity_ms separately (max of file mtime vs parsed ts)
                conn.execute(
                    "UPDATE sessions SET last_activity_ms = MAX(last_activity_ms, ?) "
                    "WHERE session_id = ? AND source = 'claude'",
                    (meta["last_ts"], meta["session_id"]),
                )
                upserted += 1
            except sqlite3.Error:
                errors += 1

    conn.commit()
    state["claude_sessions"] = session_state
    if scanned:
        suffix = f" ({errors} errors)" if errors else ""
        print(f"  [claude-sessions] scanned {scanned} files, {upserted} sessions updated{suffix}")


# --- Parsers -----------------------------------------------------------------

def parse_claude(line: str):
    """Parse a Claude Code history.jsonl line."""
    obj = json.loads(line)
    display = obj.get("display", "").strip()
    if not display:
        return None
    return {
        "source": "claude",
        "session_id": obj.get("sessionId"),
        "project": obj.get("project"),
        "prompt": display,
        "prompt_hash": _prompt_hash(display),
        "timestamp_ms": obj.get("timestamp", 0),
        "git_branch": obj.get("gitBranch"),
    }


def parse_codex(line: str):
    """Parse a Codex CLI history.jsonl line."""
    obj = json.loads(line)
    text = obj.get("text", "").strip()
    if not text:
        return None
    return {
        "source": "codex",
        "session_id": obj.get("session_id"),
        "project": None,
        "prompt": text,
        "prompt_hash": _prompt_hash(text),
        "timestamp_ms": int(obj.get("ts", 0) * 1000),
        "git_branch": None,
    }


PARSERS = {
    "claude": parse_claude,
    "codex": parse_codex,
}


# --- Codex session enrichment ------------------------------------------------
# Codex `history.jsonl` entries don't carry the working directory. The rollout
# files under ~/.codex/sessions/**/rollout-*.jsonl do — their first line is a
# `session_meta` event with `payload.id` and `payload.cwd`. We build a
# session_id → cwd map at sync time and use it to populate `project`.

def _read_codex_session_meta(path: Path):
    """Read a codex rollout file's first line; return (session_id, cwd, git_branch) or None."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            first = f.readline()
    except OSError:
        return None
    first = first.strip()
    if not first:
        return None
    try:
        obj = json.loads(first)
    except json.JSONDecodeError:
        return None
    if obj.get("type") != "session_meta":
        return None
    payload = obj.get("payload") or {}
    session_id = payload.get("id")
    cwd = payload.get("cwd")
    if not session_id or not cwd:
        return None
    git = payload.get("git") or {}
    branch = git.get("branch") if isinstance(git, dict) else None
    return session_id, cwd, branch


def build_codex_session_map(state: dict) -> tuple:
    """Walk codex rollout dirs; cache and return ({session_id: cwd}, {session_id: branch}).

    Rollout files are write-once after the session_meta header — we key the
    rollout cache by path and skip any file whose mtime hasn't changed since
    we last scanned it.
    """
    seen = state.get("codex_rollouts", {})
    cwds = state.get("codex_session_cwds", {})
    branches = state.get("codex_session_branches", {})
    scanned = 0
    for root in CODEX_SESSIONS_DIRS:
        if not root.exists():
            continue
        for rollout in root.rglob("rollout-*.jsonl"):
            key = str(rollout)
            try:
                mtime = int(rollout.stat().st_mtime)
            except OSError:
                continue
            if seen.get(key) == mtime:
                continue
            meta = _read_codex_session_meta(rollout)
            seen[key] = mtime
            scanned += 1
            if meta:
                sid, cwd, branch = meta
                cwds[sid] = cwd
                if branch:
                    branches[sid] = branch
    state["codex_rollouts"] = seen
    state["codex_session_cwds"] = cwds
    state["codex_session_branches"] = branches
    if scanned:
        print(f"  [codex] scanned {scanned:,} new rollout files; {len(cwds):,} sessions mapped")
    return cwds, branches


def _backfill_codex_projects(conn: sqlite3.Connection, cwds: dict, branches: dict) -> int:
    """Set project/git_branch for codex rows whose session_id is mapped and keep
    the sessions table in sync.

    Only sessions that still need work are touched — those with a NULL
    project/branch on some row, not yet recorded in `sessions`, or with newer
    history activity than `sessions.last_activity_ms`. Fully-synced sessions are
    skipped, so repeat syncs stay cheap regardless of total history size. The
    per-session MIN/MAX timestamps come from the same aggregate query.
    """
    if not cwds and not branches:
        return 0
    rows = conn.execute(
        """
        SELECT h.session_id,
               MIN(h.timestamp_ms), MAX(h.timestamp_ms),
               SUM(CASE WHEN h.project IS NULL THEN 1 ELSE 0 END),
               SUM(CASE WHEN h.git_branch IS NULL THEN 1 ELSE 0 END)
        FROM history h
        LEFT JOIN sessions s
          ON s.session_id = h.session_id AND s.source = 'codex'
        WHERE h.source = 'codex' AND h.session_id IS NOT NULL
        GROUP BY h.session_id
        HAVING SUM(CASE WHEN h.project IS NULL THEN 1 ELSE 0 END) > 0
            OR SUM(CASE WHEN h.git_branch IS NULL THEN 1 ELSE 0 END) > 0
            OR MAX(s.session_id) IS NULL
            OR MAX(h.timestamp_ms) > COALESCE(MAX(s.last_activity_ms), -1)
        """
    ).fetchall()
    updated = 0
    dirty = False
    for sid, first_ts, last_ts, null_proj, null_branch in rows:
        cwd = cwds.get(sid)
        branch = branches.get(sid)
        if not cwd and not branch:
            continue
        # Only write columns that are actually missing, so rowcount reflects
        # genuine changes rather than COALESCE no-ops.
        sets = []
        params = []
        if cwd and null_proj:
            sets.append("project = COALESCE(project, ?)")
            params.append(cwd)
        if branch and null_branch:
            sets.append("git_branch = COALESCE(git_branch, ?)")
            params.append(branch)
        if sets:
            params.append(sid)
            cur = conn.execute(
                f"UPDATE history SET {', '.join(sets)} WHERE source='codex' AND session_id = ?",
                params,
            )
            updated += cur.rowcount
            dirty = True
        if cwd:
            # Use real timestamps from history so sessions table sorts correctly.
            _upsert_session(conn, sid, "codex", cwd, branch, first_ts or 0)
            if last_ts:
                conn.execute(
                    "UPDATE sessions SET last_activity_ms = MAX(COALESCE(last_activity_ms, 0), ?) "
                    "WHERE session_id = ? AND source = 'codex'",
                    (last_ts, sid),
                )
            dirty = True
    if dirty:
        conn.commit()
    return updated


def sync_codex(conn: sqlite3.Connection, state: dict):
    """Import ~/.codex/history.jsonl, enriching `project` from rollout session_meta."""
    path = SOURCES["codex"]
    if not path.exists():
        print(f"  [codex] not found: {path} (skipped)")
        return

    cwds, branches = build_codex_session_map(state)

    file_size = path.stat().st_size
    offset = state.get("codex", 0)
    inserted = 0
    errors = 0

    if offset < file_size:
        print(f"  [codex] syncing {file_size - offset:,} new bytes...")
        with open(path, "r", encoding="utf-8") as f:
            f.seek(offset)
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = parse_codex(line)
                except (json.JSONDecodeError, KeyError, TypeError):
                    errors += 1
                    continue
                if row is None:
                    continue
                sid = row.get("session_id")
                if sid:
                    if not row.get("project"):
                        row["project"] = cwds.get(sid)
                    row["git_branch"] = branches.get(sid)
                try:
                    cur = conn.execute(
                        "INSERT OR IGNORE INTO history "
                        "(source, session_id, project, prompt, prompt_hash, timestamp_ms, git_branch) "
                        "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms, :git_branch)",
                        row,
                    )
                    if cur.rowcount > 0:
                        inserted += 1
                except sqlite3.Error:
                    errors += 1
        conn.commit()
        state["codex"] = file_size

    backfilled = _backfill_codex_projects(conn, cwds, branches)

    if offset >= file_size and not backfilled:
        print("  [codex] up to date")
        return
    parts = [f"+{inserted:,} rows"] if inserted or offset < file_size else []
    if backfilled:
        parts.append(f"backfilled {backfilled:,} project/branch values")
    if errors:
        parts.append(f"{errors} errors")
    print(f"  [codex] " + ", ".join(parts))


def parse_cursor_line(line: str):
    """Extract a user prompt from a cursor agent-transcripts jsonl line.

    Cursor lines have shape `{role, message: {content: [{type, text}, ...]}}`
    and carry no per-line timestamp. User prompts are wrapped in
    `<user_query>...</user_query>`.
    """
    obj = json.loads(line)
    if obj.get("role") != "user":
        return None
    msg = obj.get("message") or {}
    content = msg.get("content")
    text = ""
    if isinstance(content, str):
        text = content
    elif isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                text = c.get("text", "")
                break
    text = text.strip()
    if not text:
        return None
    if text.startswith("<user_query>") and text.endswith("</user_query>"):
        text = text[len("<user_query>"):-len("</user_query>")].strip()
    return text or None


def _decode_cursor_project(name: str) -> str:
    """Decode an encoded cursor project dir name back into a filesystem path."""
    return "/" + name.replace("-", "/")


def sync_cursor(conn: sqlite3.Connection, state: dict):
    """Sync user prompts from ~/.cursor/projects/*/agent-transcripts/."""
    if not CURSOR_ROOT.exists():
        return

    cursor_state = state.get("cursor", {})
    inserted = 0
    errors = 0
    files_seen = 0

    for project_dir in sorted(CURSOR_ROOT.iterdir()):
        if not project_dir.is_dir():
            continue
        ts_root = project_dir / "agent-transcripts"
        if not ts_root.is_dir():
            continue
        project_path = _decode_cursor_project(project_dir.name)
        for session_dir in sorted(ts_root.iterdir()):
            if not session_dir.is_dir():
                continue
            session_id = session_dir.name
            jsonl = session_dir / f"{session_id}.jsonl"
            if not jsonl.exists():
                continue
            files_seen += 1
            try:
                stat = jsonl.stat()
            except OSError:
                errors += 1
                continue
            offset = cursor_state.get(str(jsonl), 0)
            if offset >= stat.st_size:
                continue
            ts_ms = int(stat.st_mtime * 1000)
            try:
                with open(jsonl, "r", encoding="utf-8") as f:
                    f.seek(offset)
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            text = parse_cursor_line(line)
                        except (json.JSONDecodeError, KeyError, TypeError):
                            errors += 1
                            continue
                        if not text:
                            continue
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (?, ?, ?, ?, ?, ?)",
                                ("cursor", session_id, project_path, text, _prompt_hash(text), ts_ms),
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
            except OSError:
                errors += 1
                continue
            cursor_state[str(jsonl)] = stat.st_size

    conn.commit()
    state["cursor"] = cursor_state
    if files_seen:
        suffix = f" ({errors} errors)" if errors else ""
        print(f"  [cursor] +{inserted:,} rows from {files_seen} files{suffix}")


def _opencode_part_text(data: str) -> str:
    try:
        obj = json.loads(data)
    except (json.JSONDecodeError, TypeError):
        return ""
    if not isinstance(obj, dict) or obj.get("type") != "text":
        return ""
    text = obj.get("text", "")
    return text.strip() if isinstance(text, str) else ""


def _sqlite_file_marker(path: Path) -> dict:
    marker = {}
    for suffix in ("", "-wal", "-shm"):
        candidate = Path(str(path) + suffix)
        try:
            stat = candidate.stat()
            marker[suffix or "db"] = {"mtime_ns": stat.st_mtime_ns, "size": stat.st_size}
        except OSError:
            marker[suffix or "db"] = None
    return marker


def sync_opencode(conn: sqlite3.Connection, state: dict):
    """Sync user prompts from OpenCode's SQLite session store."""
    if not OPENCODE_DB.exists():
        print(f"  [opencode] not found: {OPENCODE_DB} (skipped)")
        return
    marker = _sqlite_file_marker(OPENCODE_DB)
    if marker["db"] is None:
        print(f"  [opencode] unreadable: {OPENCODE_DB} (skipped)")
        return
    if state.get("opencode") == marker:
        print("  [opencode] up to date")
        return

    with tempfile.TemporaryDirectory() as tmp:
        snapshot = Path(tmp) / "opencode.db"
        try:
            src_live = sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True, timeout=30)
            src_live.execute("PRAGMA busy_timeout=5000")
            snapshot_conn = sqlite3.connect(str(snapshot))
            src_live.backup(snapshot_conn)
            snapshot_conn.close()
            src_live.close()
            src = sqlite3.connect(str(snapshot))
            rows = src.execute(
                "SELECT s.id, s.directory, p.data, COALESCE(p.time_created, m.time_created, s.time_created) "
                "FROM part p "
                "JOIN message m ON m.id = p.message_id "
                "JOIN session s ON s.id = p.session_id "
                "WHERE json_extract(m.data, '$.role') = 'user' "
                "AND json_extract(p.data, '$.type') = 'text' "
                "ORDER BY p.time_created ASC"
            ).fetchall()
            src.close()
        except (OSError, sqlite3.Error) as e:
            print(f"  [opencode] error reading {OPENCODE_DB}: {e} (skipped)")
            return

    inserted = 0
    errors = 0
    for session_id, project, data, ts_ms in rows:
        prompt = _opencode_part_text(data)
        if not prompt:
            continue
        try:
            cur = conn.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                ("opencode", session_id, project, prompt, _prompt_hash(prompt), int(ts_ms or 0)),
            )
            if cur.rowcount > 0:
                inserted += 1
        except sqlite3.Error:
            errors += 1

    conn.commit()
    state["opencode"] = _sqlite_file_marker(OPENCODE_DB)
    print(f"  [opencode] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))


# --- Relaycast API -----------------------------------------------------------

RELAYCAST_BASE = os.environ.get("RELAYCAST_BASE_URL", "https://api.relaycast.dev")
RELAYCAST_API_KEY = os.environ.get("RELAYCAST_API_KEY", "")
RELAYCAST_WORKSPACE_ID = os.environ.get("RELAYCAST_WORKSPACE_ID", "")


def relaycast_get(path: str, params: dict = None) -> dict:  # pragma: no cover
    """Make a GET request to the Relaycast API."""
    url = f"{RELAYCAST_BASE}/v1/{path}"
    if params:
        qs = "&".join(f"{k}={v}" for k, v in params.items() if v is not None)
        if qs:
            url += f"?{qs}"
    req = urllib.request.Request(url, headers={
        "Authorization": f"Bearer {RELAYCAST_API_KEY}",
        "Accept": "application/json",
    })
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode())


def sync_relaycast(conn: sqlite3.Connection, state: dict):
    """Sync messages from Relaycast API into the history table."""
    if not RELAYCAST_API_KEY or not RELAYCAST_WORKSPACE_ID:
        return

    relay_state = state.get("relay", {})
    inserted = 0
    errors = 0

    try:
        # Sync channel messages
        resp = relaycast_get("channels")
        channels = resp.get("data", []) if resp.get("ok") else []

        for ch in channels:
            ch_name = ch.get("name", "")
            last_id = relay_state.get(f"ch:{ch_name}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"channels/{ch_name}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"#{ch_name}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                # If we got fewer than limit, we're done
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"ch:{ch_name}"] = max_id

        # Sync DM conversations
        try:
            resp = relaycast_get("dm/conversations/all")
            conversations = resp.get("data", []) if resp.get("ok") else []
        except urllib.error.HTTPError:
            conversations = []

        for conv in conversations:
            conv_id = conv.get("id", "")
            if not conv_id:
                continue
            last_id = relay_state.get(f"dm:{conv_id}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"dm/conversations/{conv_id}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"dm:{conv_id}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"dm:{conv_id}"] = max_id

        conn.commit()
        state["relay"] = relay_state
        print(f"  [relay] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
        print(f"  [relay] API error: {e}")
    except Exception as e:
        print(f"  [relay] error: {e}")


def _relay_msg_to_row(msg: dict, channel: str):
    """Convert a Relaycast message to a history row."""
    text = msg.get("text", "")
    if not text:
        return None
    sender = msg.get("from_name") or msg.get("from_id") or ""
    created_at = msg.get("created_at", "")
    ts_ms = _iso_to_ms(created_at) if created_at else 0
    prompt = f"[{sender}] {text}" if sender else text
    return {
        "source": "relay",
        "session_id": msg.get("thread_id") or channel,
        "project": RELAYCAST_WORKSPACE_ID,
        "prompt": prompt,
        "prompt_hash": _prompt_hash(prompt),
        "timestamp_ms": ts_ms,
    }


def _iso_to_ms(iso_str: str) -> int:
    """Parse ISO 8601 datetime string to milliseconds since epoch."""
    iso_str = iso_str.rstrip("Z").split("+")[0]
    frac = 0
    if "." in iso_str:
        base, frac_str = iso_str.rsplit(".", 1)
        frac = int(frac_str.ljust(3, "0")[:3])
        iso_str = base
    try:
        t = time.strptime(iso_str, "%Y-%m-%dT%H:%M:%S")
    except ValueError:
        return 0
    return int(time.mktime(t)) * 1000 + frac


# --- Trajectories ------------------------------------------------------------

def _as_text(value) -> str:
    return value if isinstance(value, str) else ""


def _as_list(value) -> list:
    return value if isinstance(value, list) else []


def _json_dump(value) -> str:
    return json.dumps(value, sort_keys=True, separators=(",", ":"))


def _trajectory_roots() -> list:
    """Resolve trajectory roots from TRAJECTORY_ROOT or ~/Projects/**/.trajectories."""
    if TRAJECTORY_ROOT.strip():
        roots = []
        for raw in TRAJECTORY_ROOT.split(os.pathsep):
            raw = raw.strip()
            if raw:
                roots.append(Path(raw).expanduser())
        return roots
    if not DEFAULT_TRAJECTORY_SEARCH_ROOT.exists():
        return []
    return sorted(
        p for p in DEFAULT_TRAJECTORY_SEARCH_ROOT.rglob(".trajectories")
        if p.is_dir()
    )


def _iter_trajectory_files() -> list:
    files = []
    for root in _trajectory_roots():
        if not root.exists():
            continue
        if root.is_file() and root.suffix == ".json":
            files.append(root)
            continue
        search_root = root.parent if root.name == "compacted" else root
        for compacted_dir in search_root.rglob("compacted"):
            if not compacted_dir.is_dir():
                continue
            for path in compacted_dir.glob("*.json"):
                if path.name in {"index.json", ".sync-state.json"}:
                    continue
                files.append(path)
    return sorted(set(files))


def _trajectory_timestamp_ms(obj: dict, path: Path) -> int:
    for key in ("completedAt", "startedAt", "compactedAt"):
        value = obj.get(key)
        if isinstance(value, str) and value:
            ts = _iso_to_ms(value)
            if ts:
                return ts
    try:
        return int(path.stat().st_mtime * 1000)
    except OSError:
        return 0


def _trajectory_search_text(obj: dict) -> str:
    task = obj.get("task") if isinstance(obj.get("task"), dict) else {}
    retrospective = obj.get("retrospective") if isinstance(obj.get("retrospective"), dict) else {}
    parts = [
        _as_text(obj.get("id")),
        _as_text(obj.get("personaId")),
        _as_text(obj.get("projectId")),
        _as_text(obj.get("status")),
        _as_text(task.get("title")),
        _as_text(task.get("description")),
    ]

    for decision in _as_list(obj.get("decisions")):
        if not isinstance(decision, dict):
            continue
        parts.extend([
            _as_text(decision.get("question")),
            _as_text(decision.get("chosen")),
            _as_text(decision.get("reasoning")),
        ])
        parts.extend(_as_text(item) for item in _as_list(decision.get("alternatives")))

    parts.extend([
        _as_text(retrospective.get("summary")),
        _as_text(retrospective.get("approach")),
        str(retrospective.get("confidence")) if retrospective.get("confidence") is not None else "",
    ])
    parts.extend(_as_text(item) for item in _as_list(retrospective.get("learnings")))
    return "\n".join(part for part in parts if part)


def parse_trajectory_file(path: Path):
    """Parse a compacted trajectory JSON file using the locked A/B contract."""
    try:
        obj = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(obj, dict):
        return None
    trajectory_id = obj.get("id")
    if not isinstance(trajectory_id, str) or not trajectory_id:
        return None
    if (
        obj.get("type") == "compacted"
        and isinstance(obj.get("sourceTrajectories"), list)
        and not any(key in obj for key in ("task", "retrospective", "personaId", "projectId"))
    ):
        return None

    task = obj.get("task") if isinstance(obj.get("task"), dict) else {}
    retrospective = obj.get("retrospective") if isinstance(obj.get("retrospective"), dict) else {}
    decisions = [d for d in _as_list(obj.get("decisions")) if isinstance(d, dict)]
    search_text = _trajectory_search_text(obj)
    ts_ms = _trajectory_timestamp_ms(obj, path)
    try:
        updated_ms = int(path.stat().st_mtime * 1000)
    except OSError:
        updated_ms = ts_ms

    return {
        "id": trajectory_id,
        "version": obj.get("version") if isinstance(obj.get("version"), int) else None,
        "persona_id": obj.get("personaId") if isinstance(obj.get("personaId"), str) else None,
        "project_id": obj.get("projectId") if isinstance(obj.get("projectId"), str) else None,
        "task_title": task.get("title") if isinstance(task.get("title"), str) else None,
        "task_description": task.get("description") if isinstance(task.get("description"), str) else None,
        "status": obj.get("status") if isinstance(obj.get("status"), str) else None,
        "started_at": obj.get("startedAt") if isinstance(obj.get("startedAt"), str) else None,
        "completed_at": obj.get("completedAt") if isinstance(obj.get("completedAt"), str) else None,
        "decisions_json": _json_dump(decisions),
        "retrospective_json": _json_dump(retrospective if isinstance(retrospective, dict) else {}),
        "search_text": search_text,
        "path": str(path),
        "updated_ms": updated_ms,
        "timestamp_ms": ts_ms,
    }


def sync_trajectories(conn: sqlite3.Connection, state: dict):
    """Sync compacted trajectory JSON files into structured and history indexes."""
    trajectory_state = state.get("trajectory", {})
    inserted = 0
    updated = 0
    skipped = 0
    errors = 0
    files = _iter_trajectory_files()

    for path in files:
        key = str(path)
        try:
            stat = path.stat()
        except OSError:
            errors += 1
            continue
        stamp = f"{int(stat.st_mtime)}:{stat.st_size}"
        if trajectory_state.get(key) == stamp:
            skipped += 1
            continue
        row = parse_trajectory_file(path)
        if not row:
            skipped += 1
            continue
        before = conn.execute(
            "SELECT 1 FROM trajectories WHERE id = ?",
            (row["id"],),
        ).fetchone()
        try:
            conn.execute(
                """
                INSERT INTO trajectories
                (id, version, persona_id, project_id, task_title, task_description, status,
                 started_at, completed_at, decisions_json, retrospective_json, search_text,
                 path, updated_ms, timestamp_ms)
                VALUES
                (:id, :version, :persona_id, :project_id, :task_title, :task_description, :status,
                 :started_at, :completed_at, :decisions_json, :retrospective_json, :search_text,
                 :path, :updated_ms, :timestamp_ms)
                ON CONFLICT(id) DO UPDATE SET
                  version=excluded.version,
                  persona_id=excluded.persona_id,
                  project_id=excluded.project_id,
                  task_title=excluded.task_title,
                  task_description=excluded.task_description,
                  status=excluded.status,
                  started_at=excluded.started_at,
                  completed_at=excluded.completed_at,
                  decisions_json=excluded.decisions_json,
                  retrospective_json=excluded.retrospective_json,
                  search_text=excluded.search_text,
                  path=excluded.path,
                  updated_ms=excluded.updated_ms,
                  timestamp_ms=excluded.timestamp_ms
                """,
                row,
            )
            conn.execute(
                "DELETE FROM history WHERE source = 'trajectory' AND session_id = ?",
                (row["id"],),
            )
            conn.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                (
                    "trajectory",
                    row["id"],
                    row["project_id"],
                    row["search_text"],
                    _prompt_hash(row["search_text"]),
                    row["timestamp_ms"],
                ),
            )
        except sqlite3.Error:
            errors += 1
            continue
        trajectory_state[key] = stamp
        if before:
            updated += 1
        else:
            inserted += 1

    conn.commit()
    state["trajectory"] = trajectory_state
    if files:
        parts = [f"+{inserted:,} rows"]
        if updated:
            parts.append(f"{updated:,} updated")
        if skipped:
            parts.append(f"{skipped:,} unchanged")
        if errors:
            parts.append(f"{errors} errors")
        print(f"  [trajectory] " + ", ".join(parts))


# --- Core --------------------------------------------------------------------

def init_db(conn: sqlite3.Connection):
    conn.executescript(SCHEMA)
    conn.execute("PRAGMA journal_mode=WAL")
    for migration in (
        "ALTER TABLE history ADD COLUMN prompt_hash TEXT",
        "ALTER TABLE history ADD COLUMN git_branch TEXT",
    ):
        try:
            conn.execute(migration)
            conn.commit()
        except sqlite3.OperationalError:
            pass  # column already exists
    conn.execute("CREATE INDEX IF NOT EXISTS idx_history_hash ON history(prompt_hash)")
    conn.execute("CREATE INDEX IF NOT EXISTS idx_trajectories_timestamp ON trajectories(timestamp_ms DESC)")
    conn.execute("CREATE INDEX IF NOT EXISTS idx_trajectories_project ON trajectories(project_id)")
    conn.execute("CREATE INDEX IF NOT EXISTS idx_tags_name ON tags(name)")
    conn.execute("CREATE INDEX IF NOT EXISTS idx_session_tags_session ON session_tags(source, session_id)")
    conn.execute("CREATE INDEX IF NOT EXISTS idx_session_tags_tag ON session_tags(tag_id)")


def load_state() -> dict:
    if STATE_PATH.exists():
        return json.loads(STATE_PATH.read_text())
    return {}


def save_state(state: dict):
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def fmt_row(id_, source, project, prompt, ts_ms, verbose=False):
    """Format a single row for display."""
    dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000))
    proj = f" [{project}]" if project else ""
    if verbose:
        display = prompt
    else:
        display = prompt[:120] + "..." if len(prompt) > 120 else prompt
        display = display.replace("\n", " ")
    return f"  #{id_:<5} {dt}  ({source}){proj}  {display}"


# --- Commands ----------------------------------------------------------------

def cmd_sync(args=None):
    """Import new entries from history files into SQLite."""
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    state = load_state()

    for name, path in SOURCES.items():
        if name == "codex":
            # Codex is handled by sync_codex with rollout-derived cwd enrichment.
            continue
        if not path.exists():
            print(f"  [{name}] not found: {path} (skipped)")
            continue

        file_size = path.stat().st_size
        offset = state.get(name, 0)
        if offset >= file_size:
            print(f"  [{name}] up to date")
            continue

        print(f"  [{name}] syncing {file_size - offset:,} new bytes...")
        parser = PARSERS[name]
        inserted = 0
        errors = 0

        with open(path, "r", encoding="utf-8") as f:
            f.seek(offset)
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = parser(line)
                except (json.JSONDecodeError, KeyError, TypeError):
                    errors += 1
                    continue
                if row is None:
                    continue
                try:
                    cur = conn.execute(
                        "INSERT OR IGNORE INTO history "
                        "(source, session_id, project, prompt, prompt_hash, timestamp_ms, git_branch) "
                        "VALUES (:source, :session_id, :project, :prompt, :prompt_hash, :timestamp_ms, :git_branch)",
                        row,
                    )
                    if cur.rowcount > 0:
                        inserted += 1
                except sqlite3.Error:
                    errors += 1

        conn.commit()
        state[name] = file_size
        print(f"  [{name}] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    # Sync Claude per-session JSONL files for gitBranch + last assistant text
    sync_claude_sessions(conn, state)

    # Sync Codex history with cwd enrichment from rollout files
    sync_codex(conn, state)

    # Sync Cursor agent transcripts (auto-discovered, no config needed)
    sync_cursor(conn, state)

    # Sync OpenCode SQLite history (auto-discovered, no config needed)
    sync_opencode(conn, state)

    # Sync Relaycast (opt-in via env vars)
    sync_relaycast(conn, state)

    # Sync compacted per-run trajectory artifacts (decision WHY)
    sync_trajectories(conn, state)

    save_state(state)
    total = conn.execute("SELECT COUNT(*) FROM history").fetchone()[0]
    conn.close()
    print(f"  Total: {total:,} entries")


